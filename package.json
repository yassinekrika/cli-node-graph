{
  "name": "cli-node-graph",
  "version": "1.0.7",
  "description": "TypeScript codebase knowledge graph analyzer (Nx-style)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "visualization/dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "bin": {
    "cli-node-graph": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:viz": "cd visualization && pnpm build",
    "build:all": "pnpm build && pnpm build:viz",
    "dev": "tsx src/cli/index.ts",
    "cli-node-graph": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "typescript",
    "dependency-graph",
    "static-analysis",
    "code-intelligence"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yassinekrika/cli-node-graph"
  },
  "homepage": "https://github.com/yassinekrika/cli-node-graph#readme",
  "bugs": {
    "url": "https://github.com/yassinekrika/cli-node-graph/issues"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "vitest": "^3.0.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
